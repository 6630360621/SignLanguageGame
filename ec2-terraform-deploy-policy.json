    {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "ECSFullAccess",
          "Effect": "Allow",
          "Action": "ecs:*",
          "Resource": "*"
        },
        {
          "Sid": "ECRFullAccess",
          "Effect": "Allow",
          "Action": "ecr:*",
          "Resource": "*"
        },
        {
          "Sid": "RDSFullAccess",
          "Effect": "Allow",
          "Action": "rds:*",
          "Resource": "*"
        },
        {
          "Sid": "EC2AndVpcFullAccess",
          "Effect": "Allow",
          "Action": "ec2:*",
          "Resource": "*"
        },
        {
          "Sid": "CloudWatchLogsFullAccess",
          "Effect": "Allow",
          "Action": "logs:*",
          "Resource": "*"
        },
        {
          "Sid": "ELBv2FullAccess",
          "Effect": "Allow",
          "Action": "elasticloadbalancing:*",
          "Resource": "*"
        },
        {
          "Sid": "IamMinimumForTerraformEcs",
          "Effect": "Allow",
          "Action": [
            "iam:CreateRole",
            "iam:DeleteRole",
            "iam:GetRole",
            "iam:GetPolicy",
            "iam:GetPolicyVersion",
            "iam:AttachRolePolicy",
            "iam:DetachRolePolicy",
            "iam:CreateServiceLinkedRole",
            "iam:SimulatePrincipalPolicy",
            "iam:ListAttachedRolePolicies",
            "iam:ListRolePolicies",
            "iam:ListRoles"
          ],
          "Resource": "*"
        },
        {
          "Sid": "IamPassRoleToEcsTasksOnly",
          "Effect": "Allow",
          "Action": "iam:PassRole",
          "Resource": "*",
          "Condition": {
            "StringEquals": {
              "iam:PassedToService": "ecs-tasks.amazonaws.com"
            }
          }
        }
      ]
    }
